include LICENSE
include README.md
include README_zh.md
include requirements.txt
recursive-include localflare/templates *
recursive-include localflare/static *
# Also include config files and locale data
recursive-include localflare/locale *
# Include default config file if present
include localflare/config.default.yaml
global-exclude __pycache__
global-exclude *.py[cod]
# Exclude editor backup files
global-exclude *~
global-exclude *.swp
# Exclude OS-generated files
global-exclude .DS_Store
global-exclude Thumbs.db
